    ''' df.to_parquet(f's3://weather-data-store/weather/transformed/{today.year}/{today.month:02d}/{today.day:02d}/weather.parquet')

    athena = boto3.client("athena", region_name="eu-central-1")
    database_query="create database if not exists weather"
    drop_table_query="DROP TABLE IF EXISTS weather.weather_today;"
    create_table_query = """
    CREATE EXTERNAL TABLE if not exists weather.weather_today (
    id bigint,
    cur_date date,
    city string,
    weather string,
    temp double,
    feels_like double,
    temp_min double,
    temp_max double,
    wind_speed double,
    sunrise string,
    sunset string
    )
    PARTITIONED BY (
    year string,
    month string,
    day string
    )

    STORED AS PARQUET
    LOCATION 's3://weather-data-store/weather/transformed/';
    """
    
    OUTPUT_LOCATION = (
    "s3://athena-weather-data/results"
    )

    queries = [database_query,drop_table_query,create_table_query]
    
    for query in queries:
        response = athena.start_query_execution(
            QueryString=query,

            ResultConfiguration={
                "OutputLocation": OUTPUT_LOCATION
            }
        )

        query_execution_id = response["QueryExecutionId"]

        logger.info(f"Running query: {query_execution_id}")

        # Wait for completion
        while True:

            result = athena.get_query_execution(
                QueryExecutionId=query_execution_id
            )

            status = (
                result["QueryExecution"]
                ["Status"]["State"]
            )

            if status in ["SUCCEEDED"]:
                logger.info("Query succeeded")
                break

            elif status in ["FAILED", "CANCELLED"]:
                reason = (
                    result["QueryExecution"]
                    ["Status"]
                    .get("StateChangeReason", "Unknown")
                )

                logger.info(f"Query failed: {reason}")
                return

            else:
                logger.info("Query still running...")
                time.sleep(2)'''
    ^
